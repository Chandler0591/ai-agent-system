# ========== LLM API ==========
# 通用变量名: LLM_API_KEY / LLM_BASE_URL (兼容 DeepSeek / OpenAI / Qwen / Ollama 等)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat
LLM_TIMEOUT=60

# ========== 多模态视觉模型（可选） ==========
# 启用后将使用视觉模型生成图片描述（用于多模态 RAG）
# 支持的 provider: openai / qwen / zhipu / moonshot / ollama
#
# ---- 本地 Ollama（推荐免费方案） ----
#   docker run -d -p 11434:11434 ollama/ollama
#   ollama pull llava:13b       (或其他视觉模型)
#   .env: VISION_PROVIDER=ollama  VISION_MODEL_NAME=llava:13b  VISION_API_KEY=ollama
#
# ---- 云端 API ----
#   openai:    VISION_API_KEY=sk-...  (GPT-4o)
#   qwen:      VISION_API_KEY=sk-...  (通义千问 qwen-vl-max)
#   zhipu:     VISION_API_KEY=...     (智谱 glm-4v)
#   moonshot:  VISION_API_KEY=sk-...  (月之暗面)
VISION_ENABLED=false
VISION_PROVIDER=openai
VISION_MODEL_NAME=gpt-4o
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=

# ========== 数据库 ==========
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ai_agent
REDIS_URL=redis://localhost:6379

# ========== 安全 ==========
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_RATE_LIMIT=60
API_RATE_WINDOW=60

# ========== 租户 ==========
DEFAULT_DOCUMENT_QUOTA=1000
DEFAULT_API_CALL_QUOTA=10000

# ========== Celery ==========
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379

# ========== 模型路径 ==========
EMBEDDING_MODEL_PATH=./models/BAAI/bge-small-zh-v1.5
RERANKER_MODEL_PATH=./models/BAAI/bge-reranker-base

# ========== 环境 ==========
ENV=development
LOG_LEVEL=INFO
